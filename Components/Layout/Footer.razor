<footer class="site-footer" style="border-top: 4px solid #3454D1; border-bottom: 2px solid #1A2332; background: #FAFAF8; padding: 32px 0; margin-top: 48px; box-shadow: 0 -4px 20px rgba(0,0,0,0.05);">
    <div class="container">
        <div class="footer-inner" style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 8px;">
            <p class="footer-copy" style="font-weight: 600; color: #1A2332; font-size: 0.9rem; margin: 0;">
                <span style="color: #3454D1; font-weight: 700;">©</span> @DateTime.Now.Year @PortfolioData.PersonalInfo.FullName.
                <span style="color: #5B6472; font-weight: 400;">Built with</span>
                <span style="color: #3454D1; font-weight: 600;">C#</span> and
                <span style="color: #3454D1; font-weight: 600;">ASP.NET Core Blazor</span>.
            </p>
        </div>
    </div>
</footer>